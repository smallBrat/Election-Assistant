# ── Dependencies (rebuilt inside container) ─────────────
node_modules/

# ── Previous build output (rebuilt inside container) ────
dist/
dist-ssr/
coverage/

# ── Git history (not needed in image) ───────────────────
.git/
.gitignore

# ── Environment / secrets ───────────────────────────────
.env
.env.*
keys/
docker-secrets/
secrets/
*.pem
*.key
*.crt
service-account*.json
*service-account*.json
*-sa*.json
*credentials*.json

# ── Logs ────────────────────────────────────────────────
logs/
*.log

# ── Editor / OS junk ────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.sw?

# ── TypeScript cache ────────────────────────────────────
*.tsbuildinfo

# ── Docs (not needed in image) ──────────────────────────
README.md
DEPLOYMENT.md
SECURITY.md
TESTING.md

# ── Local metadata ───────────────────────────────────────
.history/
