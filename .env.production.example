# Frontend build-time Firebase web config for production Vite build
# Provide these through Cloud Build substitutions passed as --build-arg in docker build.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Backend runtime config for Cloud Run service
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash
MOCK_AI=false
# Cloud Run should use service identity; do not set GOOGLE_APPLICATION_CREDENTIALS in production.
